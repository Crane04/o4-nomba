# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/o4?schema=public"

# Port for the API server
PORT=4000

# Secret used to verify Nomba webhook signatures (HMAC)
NOMBA_WEBHOOK_SECRET="replace_with_real_secret"

# Nomba API credentials
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
NOMBA_ACCOUNT_ID=

# Minimum confidence score (0-1) for auto-reconciliation.
# Anything below this goes to the manual review queue.
AUTO_MATCH_THRESHOLD=0.85
